# OJT System Frontend - Environment Configuration
#
# INSTRUCTIONS:
# 1. Copy this file to .env (DO NOT commit .env to git)
# 2. Update values for your environment
# 3. Different values for development, staging, production
#
# WHY ENVIRONMENT VARIABLES?
# - Avoid hardcoding URLs that differ per environment
# - Prevent committing sensitive data to git
# - Easy deployment to different servers
# - Different API endpoints for dev/prod

# ==================== API CONFIGURATION ====================

# VITE_API_BASE_URL
# - Base URL for all backend API requests
# - Examples:
#   Development: http://localhost:3000/api
#   Production: https://api.ojtsystem.com/api
# - DON'T include trailing slash
# - REQUIRED: Must be set for API calls to work
VITE_API_BASE_URL=http://localhost:3000/api

# ==================== API AUTHENTICATION ====================

# JWT token storage and retrieval
# - Tokens stored in localStorage with these keys
# - These are standard, don't usually need changes
# - Used in stores/authStore.js
VITE_AUTH_TOKEN_KEY=ojt_jwt_token
VITE_AUTH_ROLE_KEY=ojt_user_role

# ==================== API TIMEOUT ====================

# VITE_API_REQUEST_TIMEOUT (milliseconds)
# - How long to wait for API response before timeout
# - Default: 30000 (30 seconds)
# - Increase for slow networks/servers
# - Decrease to fail faster on bad connections
VITE_API_REQUEST_TIMEOUT=30000

# ==================== API RETRY CONFIGURATION ====================

# VITE_API_RETRY_ATTEMPTS
# - How many times to retry failed requests
# - Default: 3
# - Increases for unreliable networks
# - Set to 0 to disable retries
VITE_API_RETRY_ATTEMPTS=3

# ==================== GOOGLE OAUTH (OPTIONAL) ====================

# VITE_GOOGLE_OAUTH_CLIENT_ID
# - Google OAuth Client ID for authentication
# - Get from: https://console.developers.google.com
# - Required for Google Sign-in functionality
# VITE_GOOGLE_OAUTH_CLIENT_ID=your_client_id_here

# ==================== DEPLOYMENT NOTE ====================

# For Netlify deployment:
# - Copy .env.example to .env.production
# - Update VITE_API_BASE_URL to production backend
# - Set environment variables in Netlify dashboard (Site settings > Build & deploy > Environment)
# - Do NOT commit .env files to git

# ==================== LOGGING ====================

# VITE_DEBUG_LOGGING
# - Enable debug logging to console
# - Values: true, false
# - true = log all [API], [Router], [Component] messages
# - false = log only errors and warnings
# - Useful for troubleshooting issues
VITE_DEBUG_LOGGING=true

# ==================== FEATURE FLAGS ====================

# VITE_ENABLE_MOCK_DATA
# - Use mock/dummy data instead of real API
# - Values: true, false
# - true = useful for development without backend
# - false = use real API endpoints
VITE_ENABLE_MOCK_DATA=false

# ==================== DEPLOYMENT ====================

# VITE_APP_TITLE
# - Application title shown in browser tab
# - Default: OJT System
VITE_APP_TITLE=OJT System v2

# VITE_APP_VERSION
# - Current version for attribution
# - Example: 2.0.0
VITE_APP_VERSION=2.0.0

# ==================== ENVIRONMENT ====================

# NODE_ENV
# - Environment type
# - Values: development, staging, production
# - Automatically set by build tool, but can override
NODE_ENV=development
